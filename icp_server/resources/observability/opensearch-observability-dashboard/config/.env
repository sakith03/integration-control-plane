OPENSEARCH_INITIAL_ADMIN_PASSWORD=Ballerina@123
# Please add a minimum 8 character password and must contain at least one uppercase letter, one lowercase letter, one digit, and one special character that is strong. Password strength can be tested here: https://lowe.github.io/tryzxcvbn

# Set path to your BI logs directory to monitor both application logs and metrics logs
# e.g. BI_LOG_FILE_PATH=/path/to/bi/logs
BI_LOG_FILE_PATH=/path/to/bi/logs

# Set the path to your MI logs directory to monitor both application logs and analytics logs
# e.g. MI_LOG_FILE_PATH=/path/to/wso2mi/repository/logs
MI_LOG_FILE_PATH=/path/to/wso2mi/repository/logs
# Pattern for regular MI application logs
MI_LOG_FILE_NAME=wso2carbon-*.log
# Filename for MI Synapse analytics logs (published when analytics.enabled=true in deployment.toml)
MI_ANALYTICS_LOG_FILE_NAME=synapse-analytics-*.log
